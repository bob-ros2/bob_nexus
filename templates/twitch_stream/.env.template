# Twitch Bot Environment - The Soul of the Entity
# ---------------------------------------------

# ROS Networking
COMMON_NS=/bob
ENTITY_USE_ROS=true
#ROS_DOMAIN_ID=${ROS_DOMAIN_ID}
RMW_IMPLEMENTATION=rmw_fastrtps_cpp
ROS_SETUP_PATH=/root/ros2_ws/install/setup.bash
# streamer_v3 is automatically injected by the Nexus

# Twitch Dashboard (Visuals)
SDLVIZ_SHOW_WINDOW=false
SDLVIZ_STREAM_OUTPUT=true
SDLVIZ_STREAM_PATH=/tmp/video_pipe
SDLVIZ_AUDIO_PATH=/tmp/audio_pipe
SDLVIZ_AUDIO_MASTER_PATH=/tmp/audio_master_pipe
SDLVIZ_CONFIG_PATH="./nexus_ops.json"
#SDLVIZ_PARAMS_PATH=

# Headless Settings
SDL_VIDEODRIVER=dummy

# Twitch Credentials
TWITCH_STREAM_KEY=${TWITCH_STREAM_KEY:-"live_xxxxxxxxxx_yyy..."}
INGEST_SERVER=${TWITCH_STREAM_SERVER:-"rtmp://live-fra.twitch.tv/app/"}
ENABLE_AUDIO=false

# Render Quality
SDLVIZ_FPS=30.0
SDLVIZ_WIDTH=854
SDLVIZ_HEIGHT=480

# Brain (LLM) Settings
API_URL=${MASTER_API_URL:-"http://localhost:8000/v1"}
API_MODEL=${MASTER_API_MODEL:-"deepseek-chat"}
API_KEY=${MASTER_API_KEY:-"xyzabcdefg..."}

SYSTEM_PROMPT="You are a Twitch bot named streamer. Interact with the chat and be entertaining!"
